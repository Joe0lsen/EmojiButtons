{
  "expo": {
    "name": "Emoji Buttons",
    "slug": "EmojiButtons",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/emoji-buttons-icon.png",
    "scheme": "emojibuttons",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        // "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/emoji-buttons-icon.png"
        // "backgroundImage": "./assets/images/android-icon-background.png",
        // "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.joe0lsen.EmojiButtons"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/emoji-buttons-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/emoji-buttons-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "light": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f48d1211-be86-47f2-9501-7ed2acd3e297"
      }
    }
  }
}
